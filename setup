#!/usr/bin/env bash
set -e

# claude wrap-up skill setup script
# Installs the wrap-up skill into ~/.claude/skills/

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SKILL_NAME="wrap-up"
readonly SKILL_SOURCE="$SCRIPT_DIR/wrap-up"
readonly SKILLS_DIR="$HOME/.claude/skills"
readonly SKILL_INSTALL_DIR="$SKILLS_DIR/$SKILL_NAME"
readonly STATE_DIR="$SKILL_INSTALL_DIR/.state"
readonly SETTINGS_LOCAL="$HOME/.claude/settings.local.json"

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

# Helper functions
log_info() {
    echo -e "${BLUE}ℹ${NC}  $*"
}

log_success() {
    echo -e "${GREEN}✓${NC}  $*"
}

log_error() {
    echo -e "${RED}✗${NC}  $*" >&2
}

log_warn() {
    echo -e "${YELLOW}⚠${NC}  $*"
}

check_prerequisite() {
    local cmd=$1
    local name=$2

    if ! command -v "$cmd" &> /dev/null; then
        log_error "Missing prerequisite: $name"
        return 1
    fi
    log_success "$name installed"
}

# Main setup flow
main() {
    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  claude wrap-up skill setup${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"

    # Check prerequisites
    log_info "Checking prerequisites..."
    local all_good=true

    check_prerequisite "claude" "Claude CLI" || all_good=false

    if [ "$all_good" = false ]; then
        log_error "Claude CLI is required. Install it first: https://docs.anthropic.com/en/docs/claude-code"
        exit 1
    fi

    # Optional prerequisites (non-blocking)
    check_prerequisite "python3" "Python 3 (optional — for extract_signals.py)" || log_warn "Signal extraction script won't be available"
    check_prerequisite "git" "Git (optional — for automatic commits)" || log_warn "Git commit integration won't be available"

    echo ""

    # Verify skill source
    if [ ! -d "$SKILL_SOURCE" ]; then
        log_error "Skill source not found at: $SKILL_SOURCE"
        exit 1
    fi
    log_success "Skill source found"

    # Create skills directory if needed
    if [ ! -d "$SKILLS_DIR" ]; then
        log_info "Creating skills directory: $SKILLS_DIR"
        mkdir -p "$SKILLS_DIR"
    fi
    log_success "Skills directory ready"

    echo ""

    # Ask about installation method
    log_info "Detecting install method..."
    local install_method="copy"

    if [ -n "${CLAUDE_HOST:-}" ]; then
        log_info "CLAUDE_HOST detected: $CLAUDE_HOST"
        if [ "$CLAUDE_HOST" = "auto" ]; then
            install_method="symlink"
            log_info "Using symlink (auto mode)"
        fi
    else
        read -p "Use symlink instead of copy? (y/n) " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            install_method="symlink"
        fi
    fi

    echo ""

    # Remove existing installation
    if [ -e "$SKILL_INSTALL_DIR" ]; then
        log_warn "Existing installation found at: $SKILL_INSTALL_DIR"
        read -p "Remove and reinstall? (y/n) " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            rm -rf "$SKILL_INSTALL_DIR"
            log_success "Removed existing installation"
        else
            log_warn "Setup cancelled"
            exit 0
        fi
    fi

    # Install skill
    log_info "Installing skill ($install_method mode)..."
    if [ "$install_method" = "symlink" ]; then
        ln -s "$SKILL_SOURCE" "$SKILL_INSTALL_DIR"
        log_success "Symlinked skill to $SKILL_INSTALL_DIR"
    else
        cp -r "$SKILL_SOURCE" "$SKILL_INSTALL_DIR"
        log_success "Copied skill to $SKILL_INSTALL_DIR"
    fi

    # Make scripts executable
    log_info "Making scripts executable..."
    find "$SKILL_INSTALL_DIR/scripts" -type f -name "*.sh" -o -name "*.py" | while read -r script; do
        chmod +x "$script"
    done
    log_success "Scripts are now executable"

    echo ""

    # Initialize state directory
    log_info "Initializing state directory..."
    mkdir -p "$STATE_DIR"

    # Copy default state files if they don't exist
    if [ ! -f "$STATE_DIR/auto-wrapup.json" ]; then
        cat > "$STATE_DIR/auto-wrapup.json" <<EOF
{
  "enabled": false,
  "created_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
        log_success "Created auto-wrapup.json"
    fi

    if [ ! -f "$STATE_DIR/stats.json" ]; then
        cat > "$STATE_DIR/stats.json" <<EOF
{
  "total_sessions": 0,
  "total_rules": 0,
  "total_skill_patches": 0,
  "last_updated": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
        log_success "Created stats.json"
    fi

    echo ""

    # Ask about Stop hook configuration
    log_info "Configuring Stop hook..."
    read -p "Configure Stop hook for auto wrap-up? (y/n) " -n 1 -r
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        local hook_path="$SKILL_INSTALL_DIR/scripts/hook-stop.sh"

        # Check if settings.local.json exists
        if [ ! -f "$SETTINGS_LOCAL" ]; then
            mkdir -p "$(dirname "$SETTINGS_LOCAL")"
            echo '{}' > "$SETTINGS_LOCAL"
        fi

        # Add hook configuration (this is a simplified approach)
        log_warn "Note: Hook configuration requires manual setup in settings.local.json"
        log_info "Add this to $SETTINGS_LOCAL:"
        echo ""
        cat <<EOF
{
  "hooks": {
    "stop": ["$hook_path"]
  }
}
EOF
        echo ""
        log_warn "Please edit settings.local.json manually and restart the Claude CLI"
    fi

    echo ""

    # Print success message and available commands
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    log_success "Installation complete!"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    log_info "Available commands:"
    cat <<EOF

  /wrap-up               Run full wrap-up analysis on current session
  /wrap-up-on            Enable auto wrap-up at session end
  /wrap-up-off           Disable auto wrap-up
  /wrap-up-status        Show current configuration and stats
  /wrap-up-stats         Show learning statistics across sessions
  /wrap-up-review        Periodic review of all rules and skill health

Skill location: $SKILL_INSTALL_DIR
State directory: $STATE_DIR
EOF
    echo ""
}

main "$@"
